<Application x:Class="laba9modules.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:laba9modules"
             xmlns:vms="clr-namespace:laba9modules.ViewModels;assembly=laba9modules"
             xmlns:views="clr-namespace:laba9modules.Views;assembly=laba9modules">
    <Application.Resources>

        <DataTemplate DataType="{x:Type vms:ContactsListViewModel}">
            <views:ContactsListView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vms:AboutViewModel}">
            <views:AboutView/>
        </DataTemplate>

    </Application.Resources>
</Application>