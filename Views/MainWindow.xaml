<Window x:Class="laba9modules.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:laba9modules.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <!-- Верхнее меню / Панель навигации -->
        <Menu Height="25" Background="#E1E1E1">
            <MenuItem Header="Контакты" Command="{Binding NavigateToContactsCommand}"/>
            <MenuItem Header="О программе" Command="{Binding NavigateToAboutCommand}"/>
        </Menu>

        <!-- Область основного контента -->
        <ContentControl Content="{Binding CurrentDisplayView}"/>
    </DockPanel>
</Window>
